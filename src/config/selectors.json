      "inputBox": "textarea[placeholder*='输入'], textarea[placeholder*='问'], textarea",
      "sendButton": "button[aria-label='发送'], button[type='submit']",
      "deleteButton": ".message-actions button[aria-label='删除'], button[aria-label='删除']"
    },
    "chatgpt": {
      "messageContainer": "article[data-testid*='conversation-turn'], [data-message-author-role]",
