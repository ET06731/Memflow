      "codeBlock": "pre code, [class*='code-block'] code, .markdown-body pre",
      "inputBox": "textarea[placeholder*='输入'], textarea[placeholder*='发送'], div[class*='input'] textarea, div[contenteditable='true']",
      "sendButton": "button[type='submit'], button[class*='send'], button[aria-label*='发送']"
