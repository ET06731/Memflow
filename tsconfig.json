{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules",
    "promo-video",
    "vitest.config.ts"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "paths": {
      "~*": [
        "./*"
      ]
    },
    "baseUrl": ".",
    "types": [
      "vitest/globals",
      "@types/chrome"
    ]
  }
}